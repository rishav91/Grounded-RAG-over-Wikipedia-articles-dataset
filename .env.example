OPENAI_API_KEY=
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
COHERE_API_KEY=
# ADR-007: provider-agnostic via init_chat_model, e.g. "openai:gpt-4o-mini" or
# "anthropic:claude-haiku-4-5" — no default is assumed, this must be set.
GENERATION_MODEL=openai:gpt-4o-mini
# Optional: independently swap the faithfulness judge's model. Falls back to
# GENERATION_MODEL if unset.
FAITHFULNESS_MODEL=
